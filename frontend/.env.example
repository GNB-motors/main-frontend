# Backend API base URL. No trailing slash. Code paths prefix `/api/...`.
# Local dev (host): http://localhost:3000
# Local dev (docker compose): http://localhost:3000
# Staging/prod: set to deployed backend origin.
VITE_API_BASE_URL=http://localhost:3000

# Google Maps JS API key. Required for map-driven pages (locations, trips, etc.).
# Get one from https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=

# Optional. "true" to auto-fetch profile on dashboard mount. Default behavior
# is already enabled in DashboardLayout; flip this off to disable for debugging.
VITE_PROFILE_AUTO_FETCH=true
